# Environment Configuration
# Set to `production` on Hostinger. Locally, leave as `development`.
NODE_ENV=development

# Port the Node server listens on. Hostinger usually supplies one via the
# panel; keep this 5001 for local development.
PORT=5001

# Database Configuration (MySQL on Hostinger)
DB_HOST=srv1836.hstgr.io
DB_USER=u957836715_quotation
DB_PASSWORD=your_mysql_password
DB_NAME=u957836715_quotation_gen

# Session Secret — long random string, used to sign the session cookie.
# Generate one with: openssl rand -hex 64
SESSION_SECRET=your_session_secret_key_here

# Google OAuth 2.0 (optional). If unset, only email/password login is enabled.
# In production, set the callback in Google Cloud to:
#   https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL — only matters in development for CORS. In production the
# React build is served by Express on the same origin so CORS is disabled.
FRONTEND_URL=http://localhost:3000

# Admin Setup — only used by `npm run migrate`.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
